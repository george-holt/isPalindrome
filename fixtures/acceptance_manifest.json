{
  "schema_version": 1,
  "description": "Language-neutral acceptance tests for isPalindrome v1 (ASCII bytes, dual cursors). For expected.kind \"error\", optional expected.message is the canonical user-facing exception text (e.g. C++ palindrome_exception::what()); harnesses assert it only when their language exposes that string.",
  "error_codes": {
    "NON_ASCII_STRING_INPUT": "String / UTF-8 byte entry point: reject non-ASCII (scalar > U+007F) or any UTF-8 byte with high bit set (includes malformed sequences for C/C++ byte APIs)."
  },
  "cases": [
    {
      "id": "pal-basic-001",
      "category": "basic",
      "requirement_refs": ["REQ-CORE-LOOP", "REQ-DEFAULT-ALNUM"],
      "input_ascii": "aba",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-basic-002",
      "category": "basic",
      "requirement_refs": ["REQ-CORE-LOOP"],
      "input_ascii": "ab",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": false }
    },
    {
      "id": "pal-basic-003",
      "category": "vacuous",
      "requirement_refs": ["REQ-VACUOUS-TRUE"],
      "input_ascii": "",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-basic-004",
      "category": "basic",
      "requirement_refs": ["REQ-CORE-LOOP"],
      "input_ascii": "a",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-basic-005",
      "category": "basic",
      "requirement_refs": ["REQ-CORE-LOOP"],
      "input_ascii": "aa",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-delim-001",
      "category": "delimiters_default",
      "requirement_refs": ["REQ-DUAL-CURSOR", "REQ-DEFAULT-ALNUM"],
      "input_ascii": "A man, a plan, a canal: Panama",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-delim-002",
      "category": "delimiters_default",
      "requirement_refs": ["REQ-DUAL-CURSOR"],
      "input_ascii": "race a car",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": false }
    },
    {
      "id": "pal-delim-003",
      "category": "delimiters_default",
      "requirement_refs": ["REQ-DUAL-CURSOR"],
      "input_ascii": ".,.a.,.",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-delim-004",
      "category": "delimiters_default",
      "requirement_refs": ["REQ-DUAL-CURSOR"],
      "input_ascii": "Never odd or even",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-delim-005",
      "category": "delimiters_default",
      "requirement_refs": ["REQ-DUAL-CURSOR", "REQ-DEFAULT-ALNUM"],
      "input_ascii": ".,.a.,.....",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-delim-006",
      "category": "delimiters_default",
      "requirement_refs": ["REQ-DUAL-CURSOR", "REQ-DEFAULT-ALNUM"],
      "input_ascii": ".,,,,,,,,.a.,.",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-case-001",
      "category": "case_insensitive",
      "requirement_refs": ["REQ-ASCII-CASE-FOLD"],
      "input_ascii": "AbBa",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-case-003",
      "category": "case_insensitive",
      "requirement_refs": ["REQ-ASCII-CASE-FOLD"],
      "input_ascii": "Aa",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-digit-001",
      "category": "alnum_digits",
      "requirement_refs": ["REQ-DEFAULT-ALNUM", "REQ-CORE-LOOP"],
      "input_ascii": "121",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true },
      "notes": "Digit pairs use exact byte equality (not letter case-folding)."
    },
    {
      "id": "pal-digit-002",
      "category": "alnum_digits",
      "requirement_refs": ["REQ-DEFAULT-ALNUM", "REQ-CORE-LOOP"],
      "input_ascii": "12",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": false }
    },
    {
      "id": "pal-digit-003",
      "category": "alnum_digits",
      "requirement_refs": ["REQ-DEFAULT-ALNUM", "REQ-CORE-LOOP"],
      "input_ascii": "1a1",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true },
      "notes": "Outer pair is digit-digit; center is a single letter."
    },
    {
      "id": "pal-high-001",
      "category": "high_byte_delimiter",
      "requirement_refs": ["REQ-HIGH-BYTE-DELIM"],
      "input_hex": "61ff62",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": false }
    },
    {
      "id": "pal-high-002",
      "category": "vacuous",
      "requirement_refs": ["REQ-VACUOUS-TRUE", "REQ-HIGH-BYTE-DELIM"],
      "input_hex": "ffff",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-high-003",
      "category": "high_byte_delimiter",
      "requirement_refs": ["REQ-DUAL-CURSOR", "REQ-HIGH-BYTE-DELIM"],
      "input_hex": "61ff61",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-vac-001",
      "category": "vacuous",
      "requirement_refs": ["REQ-VACUOUS-TRUE"],
      "input_ascii": "   ",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-vac-002",
      "category": "vacuous",
      "requirement_refs": ["REQ-VACUOUS-TRUE"],
      "input_ascii": ".,;:!@#",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-custom-001",
      "category": "custom_invalid",
      "requirement_refs": ["REQ-CUSTOM-INVALID"],
      "input_ascii": "a a",
      "options": {
        "invalid_mode": "custom",
        "invalid_bytes_hex": ["20"]
      },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-custom-002",
      "category": "custom_invalid",
      "requirement_refs": ["REQ-CUSTOM-INVALID"],
      "input_ascii": "aXa",
      "options": {
        "invalid_mode": "custom",
        "invalid_bytes_hex": ["58"]
      },
      "expected": { "kind": "boolean", "value": true }
    },
    {
      "id": "pal-custom-003",
      "category": "custom_invalid",
      "requirement_refs": ["REQ-CUSTOM-INVALID"],
      "input_ascii": "hello",
      "options": {
        "invalid_mode": "custom",
        "invalid_bytes_hex": ["6c"]
      },
      "expected": { "kind": "boolean", "value": false }
    },
    {
      "id": "pal-err-001",
      "category": "custom_invalid_fallback",
      "requirement_refs": ["REQ-CUSTOM-EMPTY-FALLBACK", "REQ-DEFAULT-ALNUM"],
      "input_ascii": "ab",
      "options": {
        "invalid_mode": "custom",
        "invalid_bytes_hex": []
      },
      "expected": { "kind": "boolean", "value": false },
      "notes": "Empty custom delimiter list falls back to default alnum validity (SPEC §2)."
    },
    {
      "id": "pal-str-001",
      "category": "string_api",
      "requirement_refs": ["REQ-STRING-API-ASCII"],
      "applies_to": ["py", "cs", "nodejs", "cpp", "rust", "c"],
      "input_ascii": "aba",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true },
      "notes": "When the entry point is UTF-16 string, ASCII content must succeed."
    },
    {
      "id": "pal-str-002",
      "category": "string_api",
      "requirement_refs": ["REQ-STRING-API-NON-ASCII"],
      "applies_to": ["py", "cs", "nodejs", "cpp", "rust", "c"],
      "input_unicode_scalar": "U+00E9",
      "input_utf8_hex": "c3a9",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "error", "code": "NON_ASCII_STRING_INPUT" },
      "notes": "String U+00E9 must be rejected at API boundary."
    },
    {
      "id": "pal-str-003",
      "category": "string_api",
      "requirement_refs": ["REQ-STRING-API-ASCII"],
      "applies_to": ["py", "cs", "nodejs", "cpp", "rust", "c"],
      "input_ascii": "\u007f",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true },
      "notes": "U+007F DEL: vacuous true under default alnum."
    },
    {
      "id": "pal-str-004",
      "category": "string_api",
      "requirement_refs": ["REQ-STRING-API-NON-ASCII"],
      "applies_to": ["py", "cs", "nodejs", "cpp", "rust", "c"],
      "input_unicode_scalar": "U+0080",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "error", "code": "NON_ASCII_STRING_INPUT" },
      "notes": "Smallest scalar rejected by string API rule."
    },
    {
      "id": "pal-str-005",
      "category": "string_api",
      "requirement_refs": ["REQ-VACUOUS-TRUE", "REQ-STRING-API-ASCII"],
      "applies_to": ["py", "cs", "nodejs", "cpp", "rust", "c"],
      "input_ascii": "",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "boolean", "value": true },
      "notes": "Empty string must use string entry point (not byte-only); vacuous true."
    },
    {
      "id": "pal-str-malformed-001",
      "category": "string_api",
      "requirement_refs": ["REQ-STRING-API-NON-ASCII"],
      "applies_to": ["c", "cpp"],
      "input_utf8_hex": "80",
      "options": { "invalid_mode": "default" },
      "expected": { "kind": "error", "code": "NON_ASCII_STRING_INPUT" },
      "notes": "Lone continuation byte; C/C++ byte-string API uses same error as non-ASCII (no separate invalid-UTF-8 code)."
    },
    {
      "id": "pal-str-cpp-exception-what-001",
      "category": "string_api",
      "requirement_refs": ["REQ-STRING-API-NON-ASCII"],
      "applies_to": ["cpp"],
      "input_utf8_hex": "c3a9",
      "options": { "invalid_mode": "default" },
      "expected": {
        "kind": "error",
        "code": "NON_ASCII_STRING_INPUT",
        "message": "Input contains a scalar value > U+007F."
      },
      "notes": "C++ only: locks palindrome_exception::what() to the canonical std::exception message. Same UTF-8 as pal-str-002; separate id so reviewers see this contract in the manifest."
    },
    {
      "id": "pal-stream-note-001",
      "category": "streaming_equivalence",
      "requirement_refs": ["REQ-STREAM-BYTES"],
      "implementation_note": "File/S3 must match in-memory for same bytes; re-run pal-delim-001 and pal-high-003.",
      "reference_cases": ["pal-delim-001", "pal-high-003"]
    }
  ]
}
