# Bazel (workspace-root symlinks to output trees)
/bazel-*

# Build outputs (directories named bin/Obj at any path — e.g. .NET, generic dumps)
[Bb]in/
# Cargo puts *source* for extra binaries under src/bin/ (not Bazel/bazel-bin output).
# Re-include so those .rs files are tracked; see CLI/BUILD.bazel rust_binary srcs.
!CLI/src/bin/
!CLI/src/bin/**
[Oo]bj/
# Cargo workspace output at repository root
/target/
src/cpp/build/
src/cpp/out/
src/rust/**/target/
src/nodejs/**/node_modules/
src/c/build/
src/c/out/
reports/

[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]uild/
[Ll]og/
[Ll]ogs/

